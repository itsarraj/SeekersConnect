FROM python:3.11-slim-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-matcher.txt .
RUN pip install --no-cache-dir -r requirements-matcher.txt

COPY resume_job_matcher ./resume_job_matcher
COPY matcher_service.py .

ENV PYTHONPATH=/app
EXPOSE 8095

CMD ["python", "-m", "uvicorn", "matcher_service:app", "--host", "0.0.0.0", "--port", "8095"]
