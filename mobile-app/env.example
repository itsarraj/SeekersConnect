# Copy to .env (create next to package.json). Expo reads EXPO_PUBLIC_* at bundle time — restart Metro after edits.
# Full guide: SETUP.md

# --- Option A: USB + Expo tunnel (Metro over internet, APIs over USB) ---
# Plug phone in, then: npm run dev:android-tunnel-adb
# (runs adb reverse for 8081/8000/8080 and sets EXPO_PUBLIC_DEV_TRANSPORT=adb)

# EXPO_PUBLIC_DEV_TRANSPORT=adb

# --- Option B: same Wi-Fi, no tunnel ---
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.50
# npm run dev:android-adb   # or expo start --dev-client --lan

# --- Option C: HTTPS tunnel per backend (cloudflared, ngrok, etc.) ---
# EXPO_PUBLIC_AUTH_API_URL=https://your-auth-tunnel-host
# EXPO_PUBLIC_BFF_API_URL=https://your-bff-tunnel-host
