# Copy to repo root as `.env` for VPS deploy scripts / compose overrides.
# Never commit real `.env`.

POSTGRES_PASSWORD=change_me_strong
JWT_SECRET=change_me_long_random

# Browser-facing URLs (https in production; must match reverse-proxy hostnames)
PUBLIC_WEB_URL=https://app.example.com
PUBLIC_AUTH_URL=https://auth.example.com
PUBLIC_BFF_URL=https://api.example.com

# Hostnames for edge nginx + certbot SAN (docker-compose.vps.yml)
WEB_HOST=app.example.com
AUTH_HOST=auth.example.com
API_HOST=api.example.com
CERT_PRIMARY_DOMAIN=app.example.com

CERTBOT_EMAIL=you@example.com

# Optional: ML matcher (docker compose --profile ml)
# APP_MATCHER_BASE_URL=http://resume-matcher:8095
# MATCHER_INTERNAL_SECRET=change_me
# MATCHER_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
