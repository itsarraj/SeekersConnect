# Merge these into the repo root `.env` when using:
#   docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d --build
#
# DNS: create A records for WEB_HOST, AUTH_HOST, API_HOST → your VPS public IP.

WEB_HOST=technetium.itsarraj.xyz
AUTH_HOST=auth.technetium.itsarraj.xyz
API_HOST=api.technetium.itsarraj.xyz

# First domain passed to certbot -d … (certificate directory under /etc/letsencrypt/live/)
CERT_PRIMARY_DOMAIN=technetium.itsarraj.xyz

# Browser-facing URLs (must match https:// + hostnames above). Used at SPA build time and auth email links.
PUBLIC_WEB_URL=https://technetium.itsarraj.xyz
PUBLIC_AUTH_URL=https://auth.technetium.itsarraj.xyz
PUBLIC_BFF_URL=https://api.technetium.itsarraj.xyz

# Strong secrets (generate new values for production)
POSTGRES_PASSWORD=
JWT_SECRET=

# Optional: Resend + mail-from for universal-auth
# RESEND_API_KEY=
# APP_EMAIL_FROM=
# APP_EMAIL_FROM_NAME=

# Used by scripts/vps-issue-cert.sh for Let's Encrypt
CERTBOT_EMAIL=you@example.com
