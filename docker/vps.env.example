# Merge these into the repo root `.env` when using:
#   docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d --build
#
# DNS: create A records for WEB_HOST, AUTH_HOST, API_HOST → your VPS public IP.
# If the SPA calls https://api… or https://auth… and the browser reports
# net::ERR_NAME_NOT_RESOLVED, DNS for that hostname is missing or not propagated yet.
# Check from your laptop: dig +short api.technetium.itsarraj.xyz A
# Host nginx must proxy those names to the Docker loopback ports (see docker/host-nginx/
# technetium.itsarraj.xyz.conf.example when using host-edge).
# If you serve the site from different public hostnames (e.g. seekersconnect.xyz), set
# PUBLIC_WEB_URL / PUBLIC_AUTH_URL / PUBLIC_BFF_URL to those https:// URLs and rebuild
# matchmyresume-web so the bundle matches DNS you actually control.
# Example when using docker/host-nginx/seekersconnect-api-auth.conf.example:
#   PUBLIC_WEB_URL=https://seekersconnect.xyz
#   PUBLIC_AUTH_URL=https://auth.seekersconnect.xyz
#   PUBLIC_BFF_URL=https://api.seekersconnect.xyz
#
# Host-edge + seekersconnect-matchmyresume nginx (same-origin /api split): omit PUBLIC_AUTH_URL
# and PUBLIC_BFF_URL so the SPA uses path-only /api/... on whatever host serves the site; nginx
# routes /api/v1/auth|user|admin → auth and other /api/v1/* → BFF.

WEB_HOST=technetium.itsarraj.xyz
AUTH_HOST=auth.technetium.itsarraj.xyz
API_HOST=api.technetium.itsarraj.xyz

# First domain passed to certbot -d … (certificate directory under /etc/letsencrypt/live/)
CERT_PRIMARY_DOMAIN=technetium.itsarraj.xyz

# Browser-facing URLs (must match https:// + hostnames above). Used at SPA build time and auth email links.
PUBLIC_WEB_URL=https://technetium.itsarraj.xyz
PUBLIC_AUTH_URL=https://auth.technetium.itsarraj.xyz
PUBLIC_BFF_URL=https://api.technetium.itsarraj.xyz

# Strong secrets (generate new values for production)
POSTGRES_PASSWORD=
JWT_SECRET=

# Optional: Resend + mail-from for universal-auth
# RESEND_API_KEY=
# APP_EMAIL_FROM=
# APP_EMAIL_FROM_NAME=

# Used by scripts/vps-issue-cert.sh for Let's Encrypt
CERTBOT_EMAIL=you@example.com
