#
# seekersconnect.xyz + matchmyresume.xyz -> matchmyresume-web on loopback (host nginx).
#
# Expects these bindings from docker-compose.vps-host-edge.yml:
#   matchmyresume-web:  127.0.0.1:14680
#   universal-auth:     127.0.0.1:14681
#   matchmyresume-bff:  127.0.0.1:14682
#
# Routing:
# - /api/v1/auth|user|admin -> universal-auth (JWT + email flows)
# - all other /api/v1/*     -> matchmyresume-bff
# - everything else         -> matchmyresume-web (SPA)
#

server {
    listen 80;
    server_name seekersconnect.xyz www.seekersconnect.xyz matchmyresume.xyz www.matchmyresume.xyz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name seekersconnect.xyz www.seekersconnect.xyz matchmyresume.xyz www.matchmyresume.xyz;
    client_max_body_size 64m;

    ssl_certificate     /etc/letsencrypt/live/seekersconnect.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/seekersconnect.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location ^~ /api/v1/auth/ {
        proxy_pass http://127.0.0.1:14681;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
    location ^~ /api/v1/user/ {
        proxy_pass http://127.0.0.1:14681;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
    location ^~ /api/v1/admin/ {
        proxy_pass http://127.0.0.1:14681;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
    location ^~ /api/v1/ {
        proxy_pass http://127.0.0.1:14682;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / {
        proxy_pass http://127.0.0.1:14680;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
