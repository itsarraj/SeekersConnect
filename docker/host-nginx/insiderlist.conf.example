# Insiderlist — dedicated subdomain so apex names can serve matchmyresume-web (:14680).
#
# This file is HTTP-only on purpose: nginx will start even before DNS and TLS exist for the
# subdomain. After A record + certbot succeed, add HTTPS (see insiderlist.ssl.conf.example).
#
# If nginx currently fails nginx -t because of a missing insiderlist.* cert, replace the broken
# file with this one, then reload:
#   sudo cp ~/SeekersConnect/docker/host-nginx/insiderlist.conf.example /etc/nginx/conf.d/insiderlist.conf
#   sudo nginx -t && sudo nginx -s reload
#
# 1) DNS (required before webroot certbot; otherwise NXDOMAIN):
#    At your DNS host for zone seekersconnect.xyz, create a record:
#      Name/host: insiderlist   Type: A   Value: <this VPS public IPv4>
#    (Some panels want the full FQDN: insiderlist.seekersconnect.xyz)
#    Verify from your laptop (not only on the server):
#      dig +short insiderlist.seekersconnect.xyz A
#    Wait for TTL to expire if you changed an old record.
#
# 2) Issue cert — HTTP-01 / webroot (only after step 1 returns an A record pointing here):
#      sudo certbot certonly --webroot -w /var/www/certbot \
#        -d insiderlist.seekersconnect.xyz --email you@example.com --agree-tos --no-eff-email
#
#    If you cannot publish an A record yet but CAN add TXT records, use DNS-01 instead (no HTTP
#    fetch to this host for that name). Certbot will print a TXT name/value to add at DNS:
#      sudo certbot certonly --manual --preferred-challenges dns \
#        -d insiderlist.seekersconnect.xyz --email you@example.com --agree-tos --no-eff-email
#    After cert is issued, merge insiderlist.ssl.conf.example and reload nginx as in step 3–4.
# 3) Append HTTPS: copy lines from insiderlist.ssl.conf.example into this file (or include it),
#    then change the :80 location / block below to return 301 https://$host$request_uri;
# 4) Update Insiderlist app URL / allowed hosts to match (http first, then https).

server {
    listen 80;
    server_name insiderlist.seekersconnect.xyz;
    client_max_body_size 32m;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
