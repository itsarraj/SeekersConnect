# Insiderlist — use a dedicated subdomain so seekersconnect.xyz / matchmyresume.xyz can serve
# matchmyresume-web (127.0.0.1:14680) without duplicate server_name warnings.
#
# Before: /etc/nginx/conf.d/insiderlist.conf proxied the four apex/www names to 127.0.0.1:8080.
# After:  only insiderlist.seekersconnect.xyz → 127.0.0.1:8080
#
# 1) DNS: A record insiderlist.seekersconnect.xyz → this server (same IP as apex).
# 2) TLS (separate cert; or expand your existing seekersconnect.xyz cert and fix paths below):
#      sudo mkdir -p /var/www/certbot
#      sudo certbot certonly --webroot -w /var/www/certbot \
#        -d insiderlist.seekersconnect.xyz --email YOUR_EMAIL --agree-tos --no-eff-email
# 3) Backup and install:
#      sudo mv /etc/nginx/conf.d/insiderlist.conf /etc/nginx/conf.d/insiderlist.conf.bak
#      sudo cp docker/host-nginx/insiderlist.conf.example /etc/nginx/conf.d/insiderlist.conf
# 4) Install the marketing-site vhost (if not already):
#      sudo cp docker/host-nginx/seekersconnect-matchmyresume.xyz.conf.example \
#             /etc/nginx/conf.d/seekersconnect-matchmyresume.xyz.conf
# 5) sudo nginx -t && sudo nginx -s reload
#
# Update the Insiderlist container/app env (canonical URL, CSRF, OAuth callbacks, etc.) to
# https://insiderlist.seekersconnect.xyz — that lives outside this repo.

server {
    listen 80;
    server_name insiderlist.seekersconnect.xyz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name insiderlist.seekersconnect.xyz;
    client_max_body_size 32m;

    ssl_certificate     /etc/letsencrypt/live/insiderlist.seekersconnect.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/insiderlist.seekersconnect.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
