# HTTPS for Insiderlist — use ONLY after:
#   - DNS for insiderlist.seekersconnect.xyz works, and
#   - Cert exists at /etc/letsencrypt/live/insiderlist.seekersconnect.xyz/
#
# Merge into insiderlist.conf (same server_name as the HTTP block) and switch the :80
# location / to redirect to HTTPS, e.g.:
#   location / { return 301 https://$host$request_uri; }

server {
    listen 443 ssl;
    http2 on;
    server_name insiderlist.seekersconnect.xyz;
    client_max_body_size 32m;

    ssl_certificate     /etc/letsencrypt/live/insiderlist.seekersconnect.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/insiderlist.seekersconnect.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
