# Example host nginx for technetium.itsarraj.xyz (copy to /etc/nginx/conf.d/ as root).
# Upstream ports match docker-compose.vps-host-edge.yml (127.0.0.1:14680–14683).
#
# Requires public DNS A (or AAAA) for all three names below, or browsers show
# net::ERR_NAME_NOT_RESOLVED for API/auth requests. Verify: dig +short api.technetium.itsarraj.xyz A
#
# Issue cert first, e.g.:
#   sudo mkdir -p /var/www/certbot
#   sudo certbot certonly --webroot -w /var/www/certbot \
#     -d technetium.itsarraj.xyz -d auth.technetium.itsarraj.xyz -d api.technetium.itsarraj.xyz \
#     --email YOUR_EMAIL --agree-tos --no-eff-email

server {
    listen 80;
    server_name technetium.itsarraj.xyz auth.technetium.itsarraj.xyz api.technetium.itsarraj.xyz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name technetium.itsarraj.xyz;
    client_max_body_size 64m;

    ssl_certificate     /etc/letsencrypt/live/technetium.itsarraj.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/technetium.itsarraj.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://127.0.0.1:14680;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name auth.technetium.itsarraj.xyz;
    client_max_body_size 16m;

    ssl_certificate     /etc/letsencrypt/live/technetium.itsarraj.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/technetium.itsarraj.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://127.0.0.1:14681;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name api.technetium.itsarraj.xyz;
    client_max_body_size 64m;

    ssl_certificate     /etc/letsencrypt/live/technetium.itsarraj.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/technetium.itsarraj.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://127.0.0.1:14682;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
