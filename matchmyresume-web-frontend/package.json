{
  "name": "matchmyresume-web-frontend",
  "version": "1.0.0",
  "description": "SEO-optimized React SPA for resume matching platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:seo": "npm run build && react-snap",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 10",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "postbuild": "npm run generate-sitemap"
  },
  "keywords": [
    "react",
    "typescript",
    "seo",
    "spa",
    "tailwindcss",
    "daisyui",
    "vite"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.5.1",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "daisyui": "^4.12.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^7.1.1"
  },
  "reactSnap": {
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "crawl": true,
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/about",
      "/contact",
      "/login",
      "/register",
      "/reset-password"
    ],
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    }
  }
}
